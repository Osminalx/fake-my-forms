{
  "name": "wxt-svelte-starter",
  "description": "manifest.json description",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "test": "bun test tests/unit tests/integration tests/component",
    "test:unit": "bun test tests/unit",
    "test:int": "bun test tests/integration",
    "test:component": "bun test tests/component",
    "test:e2e": "bun run build && bun run build:firefox && bunx playwright test",
    "test:e2e:chrome": "bunx playwright test --grep Chrome",
    "test:e2e:firefox": "bunx playwright test --grep Firefox",
    "test:all": "bun run test && bun run test:e2e"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@happy-dom/global-registrator": "^20.8.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@wxt-dev/module-svelte": "^2.0.4",
    "happy-dom": "^20.8.3",
    "serve": "^14.2.6",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  }
}
